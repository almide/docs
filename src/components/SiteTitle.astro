---
import config from 'virtual:starlight/user-config';
const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
const logoDataUri = "data:image/png;base64,";
---

<div class="header-row">
  <a href={siteTitleHref} class="site-title sl-flex">
    <span class="mark-wrap">
      <img class="mark" alt="A" src={logoDataUri} width="28" height="28" />
    </span>
    <span class="label" translate="no">{siteTitle}</span>
  </a>
  <span class="subtitle">Docs</span>
</div>

<style>
  .header-row {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .site-title {
    align-items: center;
    gap: 10px !important;
    text-decoration: none !important;
    white-space: nowrap;
    min-width: 0;
    view-transition-name: site-title;
  }
  .mark-wrap {
    position: relative;
    width: 28px !important;
    height: 28px !important;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .mark {
    width: 28px !important;
    height: 28px !important;
    display: block;
    animation: logo-shimmer 6s ease-in-out infinite;
  }
  :global(:root[data-theme='light']) .mark {
    filter: grayscale(1) contrast(1.2) brightness(0.9);
    animation: none;
  }
  @keyframes logo-shimmer {
    0%   { filter: grayscale(0.6) contrast(1.2) brightness(0.9) saturate(1.2); }
    33%  { filter: grayscale(0.2) contrast(1.3) brightness(1.1) saturate(1.8); }
    66%  { filter: grayscale(0.4) contrast(1.2) brightness(1.0) saturate(1.5); }
    100% { filter: grayscale(0.6) contrast(1.2) brightness(0.9) saturate(1.2); }
  }
  .label {
    font-size: 17px !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em !important;
    overflow: hidden;
  }
  .subtitle {
    font-size: 12px;
    color: #8a8a96;
    letter-spacing: 0.02em;
  }
  :global(:root[data-theme='light']) .subtitle {
    color: #6b6b78;
  }
</style>
